generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum PreferredLang {
  ar
  en
}

enum OrgPlan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum Platform {
  META
  TIKTOK
  GOOGLE_ADS
  SNAPCHAT
  TWITTER
}

enum AdAccountStatus {
  ACTIVE
  PAUSED
  DISCONNECTED
  ERROR
  MOCK
}

enum EntityStatus {
  ACTIVE
  PAUSED
  ARCHIVED
  DELETED
}

enum CampaignPhase {
  LEARNING
  STABLE
  SCALING
  DEGRADED
}

enum OptimizerMode {
  OFF
  SUGGEST_ONLY
  AUTO_APPLY
}

enum RuleFamily {
  BUDGET
  BIDDING_STRATEGY
  BID_LIMIT
}

enum RuleComparator {
  GT
  LT
  GTE
  LTE
  EQ
}

enum ActionType {
  INCREASE_BUDGET
  DECREASE_BUDGET
  SWITCH_BIDDING_STRATEGY
  ADJUST_BID_CEILING
  ADJUST_BID_FLOOR
}

enum ActionStatus {
  PENDING
  APPLIED
  FAILED
  SKIPPED
  ROLLED_BACK
}

enum TriggeredBy {
  SCHEDULER
  MANUAL
  API
}

enum AlertType {
  BUDGET_EXHAUSTED
  HIGH_CPA
  LOW_ROAS
  DELIVERY_ISSUE
  OPTIMIZER_BLOCKED
  TOKEN_EXPIRY
  OPTIMIZER_ERROR
  LEARNING_STALLED
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum PlatformScope {
  ALL
  META
  TIKTOK
  GOOGLE_ADS
  SNAPCHAT
  TWITTER
}

enum PhaseScope {
  ALL
  STABLE
  SCALING
  DEGRADED
}

enum SettingValueType {
  STRING
  NUMBER
  BOOLEAN
  JSON
}

enum CampaignPlanStatus {
  DRAFT
  APPROVED
  LAUNCHING
  LAUNCHED
  FAILED
  ARCHIVED
}

enum CampaignPlanItemLaunchStatus {
  PENDING
  CREATING
  CREATED
  FAILED
  SKIPPED
}

enum CampaignGoal {
  AWARENESS
  TRAFFIC
  ENGAGEMENT
  LEADS
  SALES
  APP_INSTALLS
}

enum FunnelStage {
  TOFU
  MOFU
  BOFU
}

enum BudgetType {
  DAILY
  LIFETIME
}

// ─── Historical Learning Layer (Phase 1) ─────────────────────────────────────

enum DataQuality {
  CLEAN
  OUTLIER_FILTERED
  SUSPECT
}

enum SampleSizeBand {
  HIGH
  MEDIUM
  LOW
  INSUFFICIENT
}

enum FeatureConfidence {
  HIGH
  MEDIUM
  LOW
  INSUFFICIENT
  WARM_START
}

enum FeatureRunStatus {
  SUCCESS
  PARTIAL
  FAILED
  SKIPPED
}

enum FeatureRunTrigger {
  SCHEDULED
  MANUAL
  BACKFILL
}

enum OutcomeFunnelStage {
  TOF
  MOF
  BOF
  LOCAL
}

enum OutcomeAudienceType {
  COLD_INTEREST
  COLD_BROAD
  LOOKALIKE
  CUSTOM
  RETARGETING
  ENGAGEMENT
  UNKNOWN
}

enum OutcomeCreativeType {
  VERTICAL_VIDEO
  SQUARE_VIDEO
  HORIZONTAL_VIDEO
  STATIC_IMAGE
  CAROUSEL
  COLLECTION
  DPA
  AR_LENS
  STORY
  UNKNOWN
}

enum OutcomeLanguage {
  AR
  EN
  AR_EN_MIXED
  UNKNOWN
}

enum ScoringSkippedReason {
  LOW_SAMPLE
  STALE
  INSUFFICIENT_CONF
  BAD_VALUE
  STALE_INGESTION
  NULL_FEATURE
  WARM_START_INVALID
  HLL_DISABLED
  ORG_NOT_CANARY
}

enum InsightInteractionStatus {
  SEEN
  DISMISSED
  SAVED
}

enum InsightFeedback {
  USEFUL
  NOT_USEFUL
  WRONG
  NEEDS_MORE_CONTEXT
}

// ─── Users & Auth ─────────────────────────────────────────────────────────────

model User {
  id            String        @id @default(uuid())
  email         String        @unique
  passwordHash  String        @map("password_hash")
  name          String?
  avatarUrl     String?       @map("avatar_url")
  preferredLang PreferredLang @default(en) @map("preferred_lang")
  isSystemAdmin Boolean       @default(false) @map("is_system_admin")
  isActive      Boolean       @default(true) @map("is_active")
  lastLoginAt   DateTime?     @map("last_login_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  refreshTokens          RefreshToken[]
  memberships            Membership[]
  invitedMemberships     Membership[]      @relation("InvitedBy")
  optimizerActions       OptimizerAction[]
  resolvedAlerts         Alert[]
  auditLogs              AuditLog[]
  updatedAdminSettings   AdminSetting[]
  triggeredRuleTunings   RuleTuningLog[]   @relation("RuleTuningTriggeredBy")
  rolledBackRuleTunings  RuleTuningLog[]   @relation("RuleTuningRolledBackBy")
  createdPlans           CampaignPlan[]    @relation("CreatedPlans")
  approvedPlans          CampaignPlan[]    @relation("ApprovedPlans")
  updatedProviderConfigs ProviderConfig[]
  insightInteractions    InsightInteraction[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ─── Organizations ────────────────────────────────────────────────────────────

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  logoUrl   String?  @map("logo_url")
  plan      OrgPlan  @default(FREE)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  memberships               Membership[]
  adAccounts                AdAccount[]
  campaigns                 Campaign[]
  adSets                    AdSet[]
  metricSnapshots           MetricSnapshot[]
  optimizerRules            OptimizerRule[]
  optimizerActions          OptimizerAction[]
  cooldownTrackers          CooldownTracker[]
  alerts                    Alert[]
  auditLogs                 AuditLog[]
  adminSettings             AdminSetting[]
  campaignPlans             CampaignPlan[]
  campaignOutcomes          CampaignOutcome[]
  orgFeatures               OrgFeature[]
  featureComputeRuns        FeatureComputeRun[]
  platformScoringDecisions  PlatformScoringDecision[]
  insightInteractions       InsightInteraction[]

  @@map("organizations")
}

model Membership {
  id          String     @id @default(uuid())
  orgId       String     @map("org_id")
  userId      String     @map("user_id")
  role        MemberRole
  invitedById String?    @map("invited_by")
  joinedAt    DateTime?  @map("joined_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitedBy User?        @relation("InvitedBy", fields: [invitedById], references: [id])

  @@unique([orgId, userId])
  @@index([orgId])
  @@index([userId])
  @@map("memberships")
}

// ─── Ad Accounts ─────────────────────────────────────────────────────────────

model AdAccount {
  id             String          @id @default(uuid())
  orgId          String          @map("org_id")
  platform       Platform
  externalId     String          @map("external_id")
  name           String?
  currency       String          @default("USD")
  timezone       String?
  accessToken    String          @map("access_token")
  refreshToken   String?         @map("refresh_token")
  tokenExpiresAt DateTime?       @map("token_expires_at")
  status         AdAccountStatus @default(ACTIVE)
  lastSyncedAt   DateTime?       @map("last_synced_at")
  errorMessage   String?         @map("error_message")
  deletedAt      DateTime?       @map("deleted_at")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  org       Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  campaigns Campaign[]
  planItems CampaignPlanItem[]

  @@unique([orgId, platform, externalId])
  @@index([orgId])
  @@map("ad_accounts")
}

// ─── Campaigns ────────────────────────────────────────────────────────────────

model Campaign {
  id               String        @id @default(uuid())
  orgId            String        @map("org_id")
  adAccountId      String        @map("ad_account_id")
  externalId       String        @map("external_id")
  name             String
  platform         Platform
  status           EntityStatus
  objective        String?
  dailyBudget      Decimal?      @map("daily_budget") @db.Decimal(15, 4)
  lifetimeBudget   Decimal?      @map("lifetime_budget") @db.Decimal(15, 4)
  isCbo            Boolean       @default(false) @map("is_cbo")
  startDate        DateTime?     @map("start_date") @db.Date
  endDate          DateTime?     @map("end_date") @db.Date
  campaignPhase    CampaignPhase @default(LEARNING) @map("campaign_phase")
  optimizerMode    OptimizerMode @default(SUGGEST_ONLY) @map("optimizer_mode")
  phaseUpdatedAt   DateTime?     @map("phase_updated_at")
  optimizerEnabled Boolean       @default(true) @map("optimizer_enabled")
  syncedAt         DateTime?     @map("synced_at")
  sourcePlanId     String?       @map("source_plan_id")
  deletedAt        DateTime?     @map("deleted_at")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  org        Organization  @relation(fields: [orgId], references: [id])
  adAccount  AdAccount     @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  sourcePlan CampaignPlan? @relation(fields: [sourcePlanId], references: [id])
  adSets     AdSet[]

  @@unique([adAccountId, externalId])
  @@index([orgId])
  @@index([adAccountId])
  @@index([sourcePlanId])
  @@map("campaigns")
}

// ─── Ad Sets ─────────────────────────────────────────────────────────────────

model AdSet {
  id               String        @id @default(uuid())
  orgId            String        @map("org_id")
  campaignId       String        @map("campaign_id")
  externalId       String        @map("external_id")
  name             String
  status           EntityStatus
  dailyBudget      Decimal?      @map("daily_budget") @db.Decimal(15, 4)
  biddingStrategy  String?       @map("bidding_strategy")
  bidAmount        Decimal?      @map("bid_amount") @db.Decimal(15, 4)
  bidFloor         Decimal?      @map("bid_floor") @db.Decimal(15, 4)
  bidCeiling       Decimal?      @map("bid_ceiling") @db.Decimal(15, 4)
  optimizerMode    OptimizerMode @default(SUGGEST_ONLY) @map("optimizer_mode")
  optimizerEnabled Boolean       @default(true) @map("optimizer_enabled")
  syncedAt         DateTime?     @map("synced_at")
  sourcePlanItemId String?       @map("source_plan_item_id")
  deletedAt        DateTime?     @map("deleted_at")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  org            Organization      @relation(fields: [orgId], references: [id])
  campaign       Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  sourcePlanItem CampaignPlanItem? @relation(fields: [sourcePlanItemId], references: [id])

  @@unique([campaignId, externalId])
  @@index([orgId])
  @@index([campaignId])
  @@index([sourcePlanItemId])
  @@map("ad_sets")
}

// ─── Metrics ─────────────────────────────────────────────────────────────────

model MetricSnapshot {
  id           String   @id @default(uuid())
  orgId        String   @map("org_id")
  entityType   String   @map("entity_type")
  entityId     String   @map("entity_id")
  platform     Platform
  snapshotDate DateTime @map("snapshot_date") @db.Date
  windowHours  Int      @map("window_hours")
  spend        Decimal  @default(0) @db.Decimal(15, 4)
  impressions  BigInt   @default(0)
  clicks       BigInt   @default(0)
  ctr          Decimal  @default(0) @db.Decimal(10, 6)
  cpc          Decimal  @default(0) @db.Decimal(15, 4)
  conversions  BigInt   @default(0)
  cpa          Decimal  @default(0) @db.Decimal(15, 4)
  revenue      Decimal  @default(0) @db.Decimal(15, 4)
  roas         Decimal  @default(0) @db.Decimal(10, 4)
  reach        BigInt   @default(0)
  frequency    Decimal  @default(0) @db.Decimal(8, 4)
  spendPacing  Decimal  @default(0) @map("spend_pacing") @db.Decimal(8, 4)
  rawPayload   Json?    @map("raw_payload")
  dataQuality  DataQuality @default(CLEAN) @map("data_quality")
  createdAt    DateTime @default(now()) @map("created_at")

  org Organization @relation(fields: [orgId], references: [id])

  @@unique([entityType, entityId, snapshotDate, windowHours])
  @@index([orgId])
  @@index([entityType, entityId])
  @@index([snapshotDate])
  @@map("metric_snapshots")
}

// ─── Optimizer Rules ─────────────────────────────────────────────────────────

model OptimizerRule {
  id                   String         @id @default(uuid())
  orgId                String?        @map("org_id")
  ruleFamily           RuleFamily     @map("rule_family")
  name                 String
  description          String?
  isEnabled            Boolean        @default(true) @map("is_enabled")
  priority             Int            @default(100)
  kpiMetric            String         @map("kpi_metric")
  comparator           RuleComparator
  thresholdValue       Decimal        @map("threshold_value") @db.Decimal(15, 6)
  consecutiveWindows   Int            @default(1) @map("consecutive_windows")
  actionType           ActionType     @map("action_type")
  actionDelta          Decimal?       @map("action_delta") @db.Decimal(10, 4)
  actionTargetValue    String?        @map("action_target_value")
  maxDeltaPerCycle     Decimal?       @map("max_delta_per_cycle") @db.Decimal(10, 4)
  minSampleImpressions BigInt         @default(1000) @map("min_sample_impressions")
  platformScope        PlatformScope  @default(ALL) @map("platform_scope")
  appliesToPhase       PhaseScope     @default(ALL) @map("applies_to_phase")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")

  org              Organization?     @relation(fields: [orgId], references: [id])
  optimizerActions OptimizerAction[]
  ruleTuningLogs   RuleTuningLog[]

  @@index([orgId])
  @@index([ruleFamily])
  @@index([isEnabled])
  @@map("optimizer_rules")
}

// ─── Rule Tuning Log (Phase I — Controlled Auto-Tuning) ──────────────────────
// Append-only record of every threshold/disable change the auto-tuner makes.
// Powers rollback by run_id and gives admins a full audit trail of how the
// system has self-modified over time. Distinct from audit_logs (which is
// cross-cutting and append-only) so we can mark rows ROLLED_BACK without
// violating audit-log immutability.

enum RuleTuningChangeType {
  TIGHTEN_THRESHOLD
  DISABLE_RULE
}

enum RuleTuningStatus {
  APPLIED
  ROLLED_BACK
}

model RuleTuningLog {
  id                String               @id @default(uuid())
  runId             String               @map("run_id")
  orgId             String?              @map("org_id")
  ruleId            String               @map("rule_id")
  changeType        RuleTuningChangeType @map("change_type")
  fieldName         String               @map("field_name")
  beforeValue       Json                 @map("before_value")
  afterValue        Json                 @map("after_value")
  status            RuleTuningStatus     @default(APPLIED)
  triggeredByUserId String               @map("triggered_by_user_id")
  appliedAt         DateTime             @default(now()) @map("applied_at")
  rolledBackAt     DateTime?             @map("rolled_back_at")
  rolledBackById   String?               @map("rolled_back_by")
  rationale         Json

  rule            OptimizerRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  triggeredByUser User          @relation("RuleTuningTriggeredBy", fields: [triggeredByUserId], references: [id])
  rolledBackBy    User?         @relation("RuleTuningRolledBackBy", fields: [rolledBackById], references: [id])

  @@index([runId])
  @@index([ruleId])
  @@index([orgId])
  @@index([status])
  @@index([appliedAt])
  @@map("rule_tuning_logs")
}

// ─── Optimizer Actions ───────────────────────────────────────────────────────

model OptimizerAction {
  id                String       @id @default(uuid())
  orgId             String       @map("org_id")
  ruleId            String?      @map("rule_id")
  entityType        String       @map("entity_type")
  entityId          String       @map("entity_id")
  platform          Platform
  actionType        ActionType   @map("action_type")
  beforeValue       Json         @map("before_value")
  afterValue        Json         @map("after_value")
  status            ActionStatus @default(PENDING)
  appliedAt         DateTime?    @map("applied_at")
  errorMessage      String?      @map("error_message")
  triggeredBy       TriggeredBy  @default(SCHEDULER) @map("triggered_by")
  triggeredByUserId String?      @map("triggered_by_user_id")
  evaluationContext Json?        @map("evaluation_context")
  explanation       Json // { "en": "...", "ar": null }
  createdAt         DateTime     @default(now()) @map("created_at")

  org             Organization   @relation(fields: [orgId], references: [id])
  rule            OptimizerRule? @relation(fields: [ruleId], references: [id])
  triggeredByUser User?          @relation(fields: [triggeredByUserId], references: [id])

  @@index([orgId])
  @@index([entityType, entityId])
  @@index([status])
  @@index([createdAt])
  @@map("optimizer_actions")
}

// ─── Cooldown Trackers ───────────────────────────────────────────────────────

model CooldownTracker {
  id            String   @id @default(uuid())
  orgId         String   @map("org_id")
  entityType    String   @map("entity_type")
  entityId      String   @map("entity_id")
  actionType    String   @map("action_type")
  lastActionAt  DateTime @map("last_action_at")
  cooldownHours Int      @default(24) @map("cooldown_hours")
  expiresAt     DateTime @map("expires_at")

  org Organization @relation(fields: [orgId], references: [id])

  @@unique([entityType, entityId, actionType])
  @@index([expiresAt])
  @@map("cooldown_trackers")
}

// ─── Alerts ──────────────────────────────────────────────────────────────────

model Alert {
  id             String        @id @default(uuid())
  orgId          String        @map("org_id")
  entityType     String        @map("entity_type")
  entityId       String        @map("entity_id")
  alertType      AlertType     @map("alert_type")
  severity       AlertSeverity
  message        String
  context        Json?
  dedupKey       String        @map("dedup_key")
  isRead         Boolean       @default(false) @map("is_read")
  routedVia      Json          @default("[]") @map("routed_via")
  resolvedAt     DateTime?     @map("resolved_at")
  resolvedById   String?       @map("resolved_by")
  resolutionNote String?       @map("resolution_note")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  org        Organization @relation(fields: [orgId], references: [id])
  resolvedBy User?        @relation(fields: [resolvedById], references: [id])

  @@index([orgId])
  @@index([entityType, entityId])
  @@index([isRead])
  @@index([createdAt])
  @@map("alerts")
}

// ─── Audit Logs ──────────────────────────────────────────────────────────────

model AuditLog {
  id           String   @id @default(uuid())
  orgId        String?  @map("org_id")
  userId       String?  @map("user_id")
  action       String
  resourceType String   @map("resource_type")
  resourceId   String?  @map("resource_id")
  beforeState  Json?    @map("before_state")
  afterState   Json?    @map("after_state")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  createdAt    DateTime @default(now()) @map("created_at")

  org  Organization? @relation(fields: [orgId], references: [id])
  user User?         @relation(fields: [userId], references: [id])

  @@index([orgId])
  @@index([userId])
  @@index([resourceType, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Admin Settings ──────────────────────────────────────────────────────────

model AdminSetting {
  id          String   @id @default(uuid())
  orgId       String?  @map("org_id")
  key         String
  value       Json
  description String?
  isPublic    Boolean  @default(false) @map("is_public")
  updatedById String?  @map("updated_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  org       Organization? @relation(fields: [orgId], references: [id])
  updatedBy User?         @relation(fields: [updatedById], references: [id])

  @@unique([orgId, key])
  @@index([orgId])
  @@map("admin_settings")
}

// ─── Provider Configs ────────────────────────────────────────────────────────

// Per-platform OAuth + API credentials, managed by SYSTEM_ADMIN at runtime.
// Replaces hardcoded META_*/TIKTOK_*/etc. env vars. Secrets are AES-256-GCM
// encrypted at rest using ENCRYPTION_KEY (same key as AdAccount tokens).
//
// Fallback policy: NONE. If a row is missing or isEnabled=false, OAuth and
// API calls for that platform throw VALIDATION. Configure via the admin
// dashboard before any provider flow runs.
model ProviderConfig {
  id                     String   @id @default(uuid())
  platform               Platform @unique
  isEnabled              Boolean  @default(false) @map("is_enabled")
  appId                  String   @map("app_id")
  appSecretCipher        String   @map("app_secret_cipher")
  redirectUri            String   @map("redirect_uri")
  oauthStateSecretCipher String   @map("oauth_state_secret_cipher")
  apiVersion             String?  @map("api_version")
  scopes                 String[] @default([])
  extra                  Json?
  // AES-256-GCM encrypted JSON blob for sensitive platform-specific
  // credentials (e.g. Google Ads developer-token). Stored as the same
  // ciphertext format as appSecretCipher.
  extraSecretsCipher     String?  @map("extra_secrets_cipher")
  keyVersion             Int      @default(1) @map("key_version")
  updatedById            String?  @map("updated_by")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  updatedBy User? @relation(fields: [updatedById], references: [id])

  @@map("provider_configs")
}

// ─── Campaign Architect ──────────────────────────────────────────────────────

model CampaignPlan {
  id                   String             @id @default(uuid())
  orgId                String             @map("org_id")
  createdById          String             @map("created_by")
  status               CampaignPlanStatus @default(DRAFT)
  goal                 CampaignGoal
  funnelStage          FunnelStage        @map("funnel_stage")
  totalBudget          Decimal            @map("total_budget") @db.Decimal(15, 4)
  budgetType           BudgetType         @map("budget_type")
  currency             String             @default("USD")
  startDate            DateTime           @map("start_date") @db.Date
  endDate              DateTime?          @map("end_date") @db.Date
  geography            Json
  audienceHints        Json?              @map("audience_hints")
  creativeBrief        Json               @map("creative_brief")
  wizardAnswers        Json               @map("wizard_answers")
  reasoning            Json
  summary              Json
  risks                Json               @default("[]")
  warningsAcknowledged Boolean            @default(false) @map("warnings_acknowledged")
  approvedById         String?            @map("approved_by")
  approvedAt           DateTime?          @map("approved_at")
  launchedAt           DateTime?          @map("launched_at")
  deletedAt            DateTime?          @map("deleted_at")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  org              Organization              @relation(fields: [orgId], references: [id])
  createdBy        User                      @relation("CreatedPlans", fields: [createdById], references: [id])
  approvedBy       User?                     @relation("ApprovedPlans", fields: [approvedById], references: [id])
  items            CampaignPlanItem[]
  campaigns        Campaign[]
  scoringDecisions PlatformScoringDecision[]

  @@index([orgId])
  @@index([status])
  @@index([createdAt])
  @@map("campaign_plans")
}

model CampaignPlanItem {
  id                 String                       @id @default(uuid())
  planId             String                       @map("plan_id")
  platform           Platform
  adAccountId        String                       @map("ad_account_id")
  objective          String
  dailyBudget        Decimal                      @map("daily_budget") @db.Decimal(15, 4)
  isCbo              Boolean                      @default(false) @map("is_cbo")
  biddingStrategy    String                       @map("bidding_strategy")
  bidTarget          Decimal?                     @map("bid_target") @db.Decimal(15, 4)
  audience           Json
  creativeRef        Json                         @map("creative_ref")
  launchStatus       CampaignPlanItemLaunchStatus @default(PENDING) @map("launch_status")
  externalCampaignId String?                      @map("external_campaign_id")
  externalAdsetIds   Json?                        @map("external_adset_ids")
  errorMessage       String?                      @map("error_message")
  launchedAt         DateTime?                    @map("launched_at")
  historyExplanation Json?                        @map("history_explanation")
  createdAt          DateTime                     @default(now()) @map("created_at")
  updatedAt          DateTime                     @updatedAt @map("updated_at")

  plan      CampaignPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  adAccount AdAccount    @relation(fields: [adAccountId], references: [id])
  adSets    AdSet[]

  @@unique([planId, platform])
  @@index([planId])
  @@index([launchStatus])
  @@map("campaign_plan_items")
}

// ─── Historical Learning Layer — Tables ──────────────────────────────────────

// Aggregated, immutable post-flight truth for each completed campaign.
// Source for feature computation. Never updated after sealing.
model CampaignOutcome {
  id              String                @id @default(uuid())
  orgId           String                @map("org_id")
  campaignPlanId  String?               @map("campaign_plan_id")
  campaignId      String?               @map("campaign_id")
  platform        Platform
  goal            CampaignGoal
  funnelStage     OutcomeFunnelStage    @map("funnel_stage")
  audienceType    OutcomeAudienceType   @default(UNKNOWN) @map("audience_type")
  creativeType    OutcomeCreativeType   @default(UNKNOWN) @map("creative_type")
  language        OutcomeLanguage       @default(UNKNOWN)
  vertical        String?
  geoCountry      String?               @map("geo_country")
  geoRegion       String?               @map("geo_region")
  startedAt       DateTime              @map("started_at")
  endedAt         DateTime              @map("ended_at")
  durationDays    Int                   @map("duration_days")
  spend           Decimal               @default(0) @db.Decimal(15, 4)
  impressions     BigInt                @default(0)
  clicks          BigInt                @default(0)
  conversions     BigInt                @default(0)
  revenue         Decimal               @default(0) @db.Decimal(15, 4)
  ctr             Decimal               @default(0) @db.Decimal(10, 6)
  cpc             Decimal               @default(0) @db.Decimal(15, 4)
  cpa             Decimal               @default(0) @db.Decimal(15, 4)
  roas            Decimal               @default(0) @db.Decimal(10, 4)
  cpm             Decimal               @default(0) @db.Decimal(15, 4)
  dataQuality     DataQuality           @default(CLEAN) @map("data_quality")
  outlierFlags    Json                  @default("[]") @map("outlier_flags")
  sealedAt        DateTime              @default(now()) @map("sealed_at")
  createdAt       DateTime              @default(now()) @map("created_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, platform, endedAt])
  @@index([orgId, vertical, geoCountry, platform])
  @@index([campaignPlanId])
  @@index([endedAt])
  @@map("campaign_outcomes")
}

// Computed historical performance features per (org, feature, dimensions, window, version).
// orgId nullable — NULL rows are global priors used by warm-start blending.
model OrgFeature {
  id              String            @id @default(uuid())
  orgId           String?           @map("org_id")
  featureName     String            @map("feature_name")
  featureVersion  Int               @default(1) @map("feature_version")
  dimensions      Json              @default("{}")
  dimensionsKey   String            @map("dimensions_key")
  windowDays      Int               @map("window_days")
  value           Decimal?          @db.Decimal(15, 6)
  numerator       Decimal?          @db.Decimal(20, 6)
  denominator     Decimal?          @db.Decimal(20, 6)
  sampleSize      Int               @default(0) @map("sample_size")
  sampleBand      SampleSizeBand    @default(INSUFFICIENT) @map("sample_band")
  confidence      FeatureConfidence @default(INSUFFICIENT)
  isWarmStart     Boolean           @default(false) @map("is_warm_start")
  isStale         Boolean           @default(false) @map("is_stale")
  computedAt      DateTime          @default(now()) @map("computed_at")
  computedFromRunId String?         @map("computed_from_run_id")
  metadata        Json?
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  org Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, featureName, dimensionsKey, windowDays, featureVersion])
  @@index([orgId, featureName, windowDays, computedAt])
  @@index([isStale, computedAt])
  @@index([featureName, featureVersion])
  @@map("org_features")
}

// Audit trail of each feature compute run (BullMQ worker).
model FeatureComputeRun {
  id            String              @id @default(uuid())
  orgId         String?             @map("org_id")
  trigger       FeatureRunTrigger   @default(SCHEDULED)
  status        FeatureRunStatus    @default(SUCCESS)
  startedAt     DateTime            @default(now()) @map("started_at")
  finishedAt    DateTime?           @map("finished_at")
  durationMs    Int?                @map("duration_ms")
  featuresWritten Int               @default(0) @map("features_written")
  featuresSkipped Int               @default(0) @map("features_skipped")
  errorMessage  String?             @map("error_message")
  context       Json?

  org Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, startedAt(sort: Desc)])
  @@index([status, startedAt])
  @@map("feature_compute_runs")
}

// Per-platform scoring decision audit row written during DecisionEngine.build().
// One row per (plan_synthesis_run, platform). Shows whether HLL multiplier was applied or skipped.
model PlatformScoringDecision {
  id                 String                @id @default(uuid())
  orgId              String                @map("org_id")
  campaignPlanId     String?               @map("campaign_plan_id")
  planSynthesisRunId String                @map("plan_synthesis_run_id")
  platform           Platform
  goal               CampaignGoal
  funnelStage        FunnelStage           @map("funnel_stage")
  baseFitness        Decimal               @map("base_fitness") @db.Decimal(10, 6)
  multiplier         Decimal?              @db.Decimal(10, 6)
  multiplierClamped  Boolean               @default(false) @map("multiplier_clamped")
  finalScore         Decimal               @map("final_score") @db.Decimal(10, 6)
  hllApplied         Boolean               @default(false) @map("hll_applied")
  skippedReason      ScoringSkippedReason? @map("skipped_reason")
  featuresUsed       Json                  @default("[]") @map("features_used")
  confidenceSummary  Json?                 @map("confidence_summary")
  explanation        Json?
  decidedAt          DateTime              @default(now()) @map("decided_at")

  org  Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  plan CampaignPlan? @relation(fields: [campaignPlanId], references: [id], onDelete: SetNull)

  @@index([orgId, decidedAt(sort: Desc)])
  @@index([campaignPlanId])
  @@index([planSynthesisRunId])
  @@index([platform, decidedAt])
  @@map("platform_scoring_decisions")
}

// ─── Insight Interactions ─────────────────────────────────────────────────────
//
// Insights themselves are computed on-demand and never persisted, so this
// table does NOT foreign-key back to an insight row. Instead it tracks the
// (deterministic) insight ID alongside the user/org context. The insight ID
// is a SHA-1-derived string of (orgId, entityType, entityId, source) — stable
// across requests as long as the underlying entity is identifiable.
//
// One row per (insightId, userId): the row stores the *latest* status and
// feedback for that user on that insight. Updating mutates the same row
// (last-write-wins) — appropriate for dashboard UX where a user marks
// SEEN, then later DISMISSED, and we want to surface only the current state.

model InsightInteraction {
  id        String                    @id @default(uuid())
  insightId String                    @map("insight_id")
  orgId     String                    @map("org_id")
  userId    String                    @map("user_id")
  status    InsightInteractionStatus?
  feedback  InsightFeedback?
  note      String?                   @db.Text

  // Denormalized metadata captured at write-time. Insights themselves are
  // ephemeral (computed on demand, not persisted), so analytics can't join
  // back to them — these columns freeze the dimensions the user acted on
  // so feedback can be aggregated by rule / type / platform / priority.
  // All nullable so callers can omit them; older interactions also lack them.
  insightType       String?     @map("insight_type")
  severity          String?
  priority          String?
  relatedRuleId     String?     @map("related_rule_id")
  relatedActionType ActionType? @map("related_action_type")
  platform          Platform?
  entityType        String?     @map("entity_type")
  entityId          String?     @map("entity_id")

  createdAt DateTime                  @default(now()) @map("created_at")
  updatedAt DateTime                  @updatedAt @map("updated_at")

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([insightId, userId])
  @@index([orgId, userId])
  @@index([insightId])
  @@index([orgId, insightType])
  @@index([orgId, relatedRuleId])
  @@index([orgId, platform])
  @@map("insight_interactions")
}
